
#Spawn Dimension Choice - Common Configuration
[safety_features]
	#Dimensions where safety features will be applied (glass platform, clearing blocks)
	#If the list is empty, safety features will apply to all dimensions except those in blacklist
	#Format: ["minecraft:overworld", "minecraft:the_nether", "modid:dimension_id"]
	whitelistDimensions = []
	#Dimensions where safety features will NOT be applied
	#These dimensions will remain unmodified when player spawns
	#Format: ["minecraft:overworld", "minecraft:the_nether", "modid:dimension_id"]
	blacklistDimensions = ["minecraft:overworld", "minecraft:the_end"]
	#The block to use for spawning platforms
	platformBlockId = "minecraft:glass"

